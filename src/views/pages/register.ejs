<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Register — DevConnect</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: sans-serif; background: #0f0f1a; color: #eee; display: flex; flex-direction: column; min-height: 100vh; }
    .card { background: #1a1a2e; max-width: 420px; margin: 80px auto; padding: 40px; border-radius: 10px; }
    h2 { color: #e94560; margin-bottom: 24px; text-align: center; }
    input { width: 100%; padding: 12px; margin-bottom: 16px; background: #0f0f1a; border: 1px solid #333; border-radius: 6px; color: #eee; font-size: 1rem; }
    button { width: 100%; padding: 12px; background: #e94560; border: none; border-radius: 6px; color: #fff; font-size: 1rem; cursor: pointer; }
    button:hover { background: #c73652; }
    .error { color: #e94560; margin-bottom: 14px; text-align: center; }
    .link { text-align: center; margin-top: 16px; color: #888; }
    .link a { color: #e94560; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Create Account</h2>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form action="/api/auth/register" method="POST" id="registerForm">
      <input type="text" name="name" placeholder="Your name" required />
      <input type="email" name="email" placeholder="Email address" required />
      <input type="password" name="password" placeholder="Password" required />
      <button type="submit">Register</button>
    </form>
    <p class="link">Already have an account? <a href="/login">Login</a></p>
  </div>

  <script>
    // after register, redirect to login
    document.getElementById("registerForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch("/api/auth/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (res.ok) {
        window.location.href = "/login";
      } else {
        document.querySelector(".error") 
          ? (document.querySelector(".error").textContent = json.error)
          : alert(json.error);
      }
    });
  </script>
</body>
</html>
